#!/usr/bin/env bash
# SessionStart hook: force-inject the ODD workflow into the agent's context so
# it engages even where native skill auto-discovery wouldn't fire (e.g. headless
# ACP runs). Mirrors the Superpowers using-superpowers bootstrap pattern.
#
# Resolves SKILL.md relative to this hook (…/skills/odd/hooks/session-start ->
# …/skills/odd/SKILL.md), so it works wherever the skill folder is installed.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILL_MD="${SCRIPT_DIR}/../SKILL.md"
ODD_BIN="$(cd "${SCRIPT_DIR}/../bin" && pwd)/odd"

skill_content="$(cat "$SKILL_MD" 2>/dev/null || echo "Error reading ODD SKILL.md")"

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_escaped=$(escape_for_json "$skill_content")
odd_bin_escaped=$(escape_for_json "$ODD_BIN")
context="<EXTREMELY_IMPORTANT>\nYou MUST follow the Outcome-Driven Development (ODD) workflow below for this task. The \`odd\` CLI is at ${odd_bin_escaped} — invoke it by that full path (e.g. \`${odd_bin_escaped} init\`), or add its directory to PATH first. Use it: \`odd init\`, \`odd check\`, \`odd prove\`, \`odd review\`. Do not declare the task done until \`odd prove\` shows fresh passing evidence.\n\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"

# Emit formats for Claude Code (hookSpecificOutput), Cursor (additional_context),
# and legacy SDK consumers (top-level additionalContext).
if [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ] && [ -z "${CURSOR_TRACE_ID:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context"
else
  printf '{\n  "additional_context": "%s",\n  "additionalContext": "%s",\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$context" "$context" "$context"
fi
exit 0
